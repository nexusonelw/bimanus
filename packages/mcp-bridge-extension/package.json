{
  "name": "@bimanus/mcp-bridge-extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "displayName": "MCP Bridge",
  "description": "Expose configured HTTP MCP servers as pi tools",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:bridge": "pnpm run build && node scripts/test-bridge.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@types/node": "^22.13.0"
  }
}
